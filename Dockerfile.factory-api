FROM golang:1.22 AS build
WORKDIR /src
COPY go.mod ./
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/factory-api ./cmd/factory-api

FROM alpine:3.20
WORKDIR /workspace
ARG CODEX_NPM_PACKAGE=@openai/codex@latest
RUN apk add --no-cache ca-certificates bash curl nodejs npm \
  && npm install -g "${CODEX_NPM_PACKAGE}"
COPY --from=build /out/factory-api /usr/local/bin/factory-api
EXPOSE 8080
ENV FACTORY_API_ADDR=:8080
ENTRYPOINT ["/usr/local/bin/factory-api"]
