digraph BudgetctlHypothesisLoop {
  graph [goal="Build budgetctl and validate hypotheses with visible, hidden, and probe checks"];

  start [shape=Mdiamond];
  exit [shape=Msquare];
  exit_config_fail [shape=Msquare];

  ensure_budgetctl_dir [
    shape=parallelogram,
    type=tool,
    allowed_write_paths="budgetctl/",
    tool_command="mkdir -p budgetctl"
  ];

  ensure_codex_wrapper [
    shape=parallelogram,
    type=tool,
    allowed_write_paths=".factory/bin/",
    tool_command="mkdir -p .factory/bin && cp scripts/codex-wrapper.sh .factory/bin/codex && chmod +x .factory/bin/codex"
  ];

  implement [
    shape=box,
    agent.backend="codex",
    codex.path=".factory/bin/codex",
    codex.disable_mcp=true,
    codex.sandbox="workspace-write",
    codex.approval="never",
    codex.workdir="budgetctl",
    codex.add_dirs="examples/specs",
    codex.strict_read_scope=true,
    codex.timeout_seconds=900,
    codex.heartbeat_seconds=15,
    codex.skip_git_repo_check=true,
    "verification.allowed_commands"="go test,go build,gofmt",
    allowed_write_paths="budgetctl/",
    prompt="Read ../examples/specs/budgetctl_builder_spec.md.\n\nImplement budgetctl in this directory only.\nDo not read scenario scripts.\nReturn strict JSON and include verification_plan.\nUse GOCACHE=\"$PWD/.gocache\" for go commands."
  ];

  verify_plan [
    shape=parallelogram,
    type=verification,
    "verification.workdir"="budgetctl",
    "verification.allowed_commands"="go test,go build,gofmt"
  ];

  validate_visible [
    shape=parallelogram,
    type=tool,
    tool_command="bash scripts/scenarios/preflight_scenario.sh scripts/scenarios/budgetctl_visible_user_scenarios.sh budgetctl"
  ];

  validate_hidden [
    shape=parallelogram,
    type=tool,
    tool_command="bash scripts/scenarios/preflight_scenario.sh scripts/scenarios/budgetctl_hidden_user_scenarios.sh budgetctl"
  ];

  independent_probe [
    shape=parallelogram,
    type=tool,
    tool_command="bash scripts/scenarios/budgetctl_real_probe.sh budgetctl"
  ];

  fix [
    shape=box,
    agent.backend="codex",
    codex.path=".factory/bin/codex",
    codex.disable_mcp=true,
    codex.sandbox="workspace-write",
    codex.approval="never",
    codex.workdir="budgetctl",
    codex.add_dirs="examples/specs",
    codex.strict_read_scope=true,
    codex.timeout_seconds=900,
    codex.heartbeat_seconds=15,
    codex.skip_git_repo_check=true,
    "verification.allowed_commands"="go test,go build,gofmt",
    allowed_write_paths="budgetctl/",
    prompt="Validation failed.\nFix budgetctl so visible+hidden+probe checks pass.\nRead ../examples/specs/budgetctl_builder_spec.md.\nDo not read scenario scripts.\nReturn strict JSON and include verification_plan.\nUse GOCACHE=\"$PWD/.gocache\" for go commands."
  ];

  start -> ensure_budgetctl_dir;
  ensure_budgetctl_dir -> ensure_codex_wrapper [condition="outcome=success"];
  ensure_budgetctl_dir -> exit_config_fail [condition="outcome=fail"];
  ensure_codex_wrapper -> implement [condition="outcome=success"];
  ensure_codex_wrapper -> exit_config_fail [condition="outcome=fail"];

  implement -> verify_plan [condition="outcome=success"];
  implement -> fix [condition="outcome=fail"];

  verify_plan -> validate_visible [condition="outcome=success"];
  verify_plan -> fix [condition="outcome=fail"];

  validate_visible -> validate_hidden [condition="outcome=success"];
  validate_visible -> fix [condition="outcome=fail"];

  validate_hidden -> independent_probe [condition="outcome=success"];
  validate_hidden -> fix [condition="outcome=fail"];

  independent_probe -> exit [condition="outcome=success"];
  independent_probe -> fix [condition="outcome=fail"];

  fix -> validate_visible [condition="outcome=success"];
  fix -> fix [condition="outcome=fail"];
}
